# Keep Docker build context small and deterministic

# Python cache/artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Local configs/secrets
.env
.env.*
!.env.example

# VCS/editor/OS files
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs/temp
*.log
tmp/
temp/

# Local data artifacts
uploads/

# Build/deployment files not needed inside image runtime
deployments/
docs/
scripts/

# Ensure entrypoint is always included
!entrypoint.sh